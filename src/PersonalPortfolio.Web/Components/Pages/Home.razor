@page "/"

<PageTitle>@Profile.Name — @Profile.Title</PageTitle>

<Hero />

@* Section anchors below are wired for navigation and active-highlight.
   Each section's content is implemented in a later step. *@

<About />

<Skills />

<section id="projects" class="section-anchor page-section">
    <h2 class="section-title">Projects</h2>
    <div class="project-grid">
        @foreach (var project in Profile.Projects)
        {
            <article class="project-card">
                <div class="project-card-head">
                    <h3 class="project-name">@project.Name</h3>
                    <span class="project-status status-@project.Status.Replace(" ", "-").ToLowerInvariant()">
                        @project.Status
                    </span>
                </div>
                <p class="project-desc">@project.Description</p>
                <div class="project-tech">
                    @foreach (var tech in project.Tech)
                    {
                        <span class="tech-tag">@tech</span>
                    }
                </div>
                @if (project.RepoUrl is not null)
                {
                    <a class="project-link" href="@project.RepoUrl" target="_blank" rel="noopener">
                        <i class="fa-brands fa-github me-1"></i>View on GitHub
                    </a>
                }
            </article>
        }
    </div>
</section>

<section id="experience" class="section-anchor experience">
    <div class="experience-head">
        <h2 class="experience-title">Experience</h2>
    </div>

    <ul class="experience-list">
        @foreach (var item in Profile.Timeline)
        {
            <li class="experience-item">
                <span class="experience-period">@item.Period</span>
                <div class="experience-body">
                    <h3 class="experience-role">@item.Title</h3>
                    <p class="experience-summary">@item.Summary</p>
                </div>
            </li>
        }
    </ul>
</section>

<section id="contact" class="section-anchor page-section">
    <h2 class="section-title">Contact</h2>
    <p class="lead-text">Feel free to reach out — I'm open to interesting backend and distributed systems work.</p>
    <div class="contact-list">
        <a class="contact-item" href="mailto:@Profile.Email">
            <i class="fa-solid fa-envelope"></i>
            <span>@Profile.Email</span>
        </a>
        <a class="contact-item" href="@Profile.GitHubUrl" target="_blank" rel="noopener">
            <i class="fa-brands fa-github"></i>
            <span>GitHub</span>
        </a>
        <a class="contact-item" href="@Profile.LinkedInUrl" target="_blank" rel="noopener">
            <i class="fa-brands fa-linkedin"></i>
            <span>LinkedIn</span>
        </a>
    </div>
</section>
