@page "/projects"

<PageTitle>Projects — @Profile.Name</PageTitle>

<section class="page-section">
    <h1 class="section-title">Projects</h1>
    <p class="lead-text">A selection of things I'm building. More will be wired up to GitHub later.</p>

    <div class="project-grid">
        @foreach (var project in Profile.Projects)
        {
            <article class="project-card">
                <div class="project-card-head">
                    <h2 class="project-name">@project.Name</h2>
                    <span class="project-status status-@project.Status.Replace(" ", "-").ToLowerInvariant()">
                        @project.Status
                    </span>
                </div>
                <p class="project-desc">@project.Description</p>
                <div class="project-tech">
                    @foreach (var tech in project.Tech)
                    {
                        <span class="tech-tag">@tech</span>
                    }
                </div>
                @if (project.RepoUrl is not null)
                {
                    <a class="project-link" href="@project.RepoUrl" target="_blank" rel="noopener">
                        <i class="fa-brands fa-github me-1"></i>View on GitHub
                    </a>
                }
            </article>
        }
    </div>
</section>
