@* Skills — technologies grouped by category, shown as clean text tags. *@

<section id="skills" class="section-anchor page-section">
    <h2 class="section-title">Skills</h2>
    <p class="lead-text">Tools and technologies I reach for when building backend systems.</p>

    <div class="skill-groups">
        @foreach (var group in Profile.SkillGroups)
        {
            <div class="skill-group">
                <h3 class="skill-group-title">@group.Category</h3>
                <div class="skill-tags">
                    @foreach (var item in group.Items)
                    {
                        <span class="skill-tag">@item</span>
                    }
                </div>
            </div>
        }
    </div>
</section>
