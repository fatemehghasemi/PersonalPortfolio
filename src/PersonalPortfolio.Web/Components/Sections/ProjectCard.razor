@* ProjectCard — a single reusable project card. *@

<article class="project-card">
    <div class="project-thumb" aria-hidden="true">
        <span class="project-thumb-initial">@Project.Name[..1]</span>
    </div>

    <div class="project-card-body">
        <div class="project-card-head">
            <h3 class="project-name">@Project.Name</h3>
            <span class="project-status status-@StatusSlug">@Project.Status</span>
        </div>

        <p class="project-desc">@Project.Description</p>

        <div class="project-tech">
            @foreach (var tech in Project.Tech)
            {
                <span class="tech-tag">@tech</span>
            }
        </div>

        <div class="project-links">
            @if (Project.RepoUrl is not null)
            {
                <a class="project-link" href="@Project.RepoUrl" target="_blank" rel="noopener">
                    <i class="fa-brands fa-github me-1"></i>Code
                </a>
            }
            @if (Project.DemoUrl is not null)
            {
                <a class="project-link" href="@Project.DemoUrl" target="_blank" rel="noopener">
                    <i class="fa-solid fa-arrow-up-right-from-square me-1"></i>Demo
                </a>
            }
        </div>
    </div>
</article>

@code {
    [Parameter, EditorRequired]
    public ProjectItem Project { get; set; } = default!;

    private string StatusSlug => Project.Status.Replace(" ", "-").ToLowerInvariant();
}
