@rendermode InteractiveServer
@inject IJSRuntime JS

<nav class="site-nav">
    <a class="nav-brand" href="">@Profile.Name</a>

    <div class="nav-links">
        <NavLink class="nav-link" href="" Match="NavLinkMatch.All">Home</NavLink>
        <NavLink class="nav-link" href="about">About</NavLink>
        <NavLink class="nav-link" href="projects">Projects</NavLink>
        <NavLink class="nav-link" href="contact">Contact</NavLink>
    </div>

    <button class="theme-toggle" @onclick="ToggleTheme" aria-label="Toggle theme" title="Toggle theme">
        <i class="fa-solid @(_theme == "dark" ? "fa-moon" : "fa-sun")"></i>
    </button>
</nav>

@code {
    private string _theme = "dark";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _theme = await JS.InvokeAsync<string>("portfolioTheme.current");
            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
    {
        _theme = await JS.InvokeAsync<string>("portfolioTheme.toggle");
    }
}
