<Project>

  <PropertyGroup>
    <!-- Common build settings shared by all projects in this repository -->
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
  </PropertyGroup>

  <PropertyGroup>
    <!-- Repository identity -->
    <Authors>Fatemeh Ghasemi</Authors>
    <Company>PersonalPortfolio</Company>
    <Product>PersonalPortfolio</Product>
    <Copyright>Copyright © Fatemeh Ghasemi</Copyright>
    <RepositoryUrl>https://github.com/fatemehghasemi/PersonalPortfolio</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
  </PropertyGroup>

</Project>
